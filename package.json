{
  "name": "metadata-change-guard",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @crashtest/api --filter @crashtest/web dev",
    "test": "vitest run tests/*.test.ts",
    "test:packages": "pnpm -r --filter @crashtest/* test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "supertest": "^7.0.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
